<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NinjaSecurity.App.Views.ScanView">
  <DockPanel Margin="32">

    <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,16">
      <TextBlock Text="Сканирование" FontSize="24" FontWeight="Bold" Foreground="White" />

      <StackPanel Orientation="Horizontal" Spacing="16">
        <RadioButton Content="Быстрое" IsChecked="{Binding IsQuick}" Foreground="White" />
        <RadioButton Content="Полное" IsChecked="{Binding IsFull}" Foreground="White" />
        <RadioButton Content="Выборочное" IsChecked="{Binding IsCustom}" Foreground="White" />
      </StackPanel>

      <TextBox IsVisible="{Binding IsCustom}"
               Text="{Binding CustomPath}"
               Watermark="Путь к папке или файлу..."
               Classes="DarkInput" />

      <StackPanel Orientation="Horizontal" Spacing="16">
        <Button Command="{Binding StartScanCommand}"
                IsEnabled="{Binding !IsScanning}"
                Classes="PrimaryButton"
                Content="⚔  Начать сканирование" />
        <TextBlock Text="{Binding StatusText}" Foreground="#888"
                   VerticalAlignment="Center" />
      </StackPanel>
    </StackPanel>

    <DataGrid ItemsSource="{Binding Threats}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Classes="DarkGrid">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Файл" Binding="{Binding FilePath}" Width="*" />
        <DataGridTextColumn Header="Угроза" Binding="{Binding ThreatName}" Width="200" />
        <DataGridTextColumn Header="Риск" Binding="{Binding ConfidenceScore}" Width="80" />
      </DataGrid.Columns>
    </DataGrid>

  </DockPanel>
</UserControl>
